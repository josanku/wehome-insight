# AWS Elastic Beanstalk Python 3.11 환경 설정
option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: server:app
    NumProcesses: 2
    NumThreads: 15

  aws:elasticbeanstalk:application:environment:
    PYTHONPATH: "/var/app/current"
    PYTHONUNBUFFERED: "1"
    FLASK_ENV: production
    # KAKAO_REST_API_KEY: 별도 EB Console에서 설정

  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: static

  aws:autoscaling:launchconfiguration:
    InstanceType: t3.small

container_commands:
  01_fetch_data:
    command: "python fetch_data.py || true"
    leader_only: true
